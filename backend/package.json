{
  "name": "pxlr-cms-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "PXLR Headless CMS Backend",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build-css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/styles.css",
    "watch-css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/styles.css --watch",
    "sync-pages": "node sync-pages.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "fs-extra": "^11.1.1",
    "express-rate-limit": "^6.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "tailwindcss": "^4.1.11",
    "@tailwindcss/cli": "^4.1.11"
  }
} 